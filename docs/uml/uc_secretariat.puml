@startuml uc_secretariat

title Cas d'utilisation — Secrétariat

left to right direction

skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #D6E4F0
    BorderColor #1F4E79
    ArrowColor #1F4E79
    ActorBorderColor #1F4E79
    ActorBackgroundColor #EAF4FB
}

' ── Acteurs ──────────────────────────────────────
actor "Secrétariat" as SEC
actor "Système"     as SYS

' ── Frontière du système ─────────────────────────
rectangle "Application Asimut" {

    ' Gestion des élèves
    usecase "Importer un fichier CSV\nd'élèves de 6e"         as UC1
    usecase "Détecter les doublons"                            as UC1a
    usecase "Créer un élève manuellement"                      as UC2

    ' Gestion des moyennes
    usecase "Saisir une moyenne\npar semestre"                 as UC3

    ' Gestion des référents
    usecase "Affecter un enseignant\nréférent à un élève"      as UC4
    usecase "Affectation automatique\n(round-robin)"           as UC4a
    usecase "Affectation manuelle"                             as UC4b

    ' Gestion des parents
    usecase "Enregistrer les infos\nd'un parent"               as UC5

    ' Gestion des projets
    usecase "Valider un projet\nsoumis par un élève"           as UC6

}

' ── Relations Secrétariat ────────────────────────
SEC --> UC1
SEC --> UC2
SEC --> UC3
SEC --> UC4
SEC --> UC5
SEC --> UC6

' ── Extensions et inclusions ─────────────────────

' L'import CSV inclut toujours la détection des doublons
UC1 .> UC1a : <<include>>

' L'affectation peut être automatique ou manuelle
UC4 .> UC4a : <<extend>>
UC4 .> UC4b : <<extend>>

' Le système prend en charge le round-robin automatiquement
SYS --> UC4a

@enduml
